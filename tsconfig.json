{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@thevault/contracts": [
        "packages/contracts/src/index.ts"
      ],
      "@thevault/contracts/*": [
        "packages/contracts/src/*"
      ],
      "@thevault/domain": [
        "packages/domain/src/index.ts"
      ],
      "@thevault/domain/*": [
        "packages/domain/src/*"
      ],
      "@thevault/config": [
        "packages/config/src/index.ts"
      ],
      "@thevault/config/*": [
        "packages/config/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts"
  ]
}
