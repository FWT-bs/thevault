# Copy this file to apps/api/.env.local and paste your server-only values.
# Never put SUPABASE_SERVICE_ROLE_KEY in EXPO_PUBLIC_* variables or client code.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SECRET_KEY=your_supabase_secret_key
SUPABASE_PROJECT_ID=your-project-ref

# Legacy fallback if your project still uses service_role JWT keys:
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_secret_key
