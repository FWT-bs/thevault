{
  "name": "@thevault/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch api/dev.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "supabase:db:reset": "npx -y supabase db reset --workdir ../../infra/supabase",
    "supabase:types": "npx -y supabase gen types typescript --project-id \"$SUPABASE_PROJECT_ID\" --schema public > ../../packages/contracts/src/generated/supabase.ts",
    "smoke": "tsx scripts/smoke.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "@vercel/node": "^5.3.20",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
