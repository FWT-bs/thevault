# Copy this file to .env.local and paste your browser/mobile-safe values.
# Only EXPO_PUBLIC_* variables are bundled into the Expo app.

EXPO_PUBLIC_API_BASE_URL=http://localhost:3000/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_publishable_key

# Optional legacy fallback. Prefer EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY for new keys.
# EXPO_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key

# Google OAuth client IDs (Google Cloud Console → Credentials).
# iOS: set both WEB and IOS client IDs or the app skips mounting the Google auth hook.
# Android: set WEB and ANDROID. Web/Expo Go: WEB is enough.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# Optional: only set if you have a separate Expo proxy client.
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=

# When "true", supported mini-games launch via the Unity host instead of the
# React Native implementations under components/games/. Defaults to false.
# See MIGRATION_UNITY.md for the migration plan and per-game status.
EXPO_PUBLIC_USE_UNITY_MINIGAMES=false
