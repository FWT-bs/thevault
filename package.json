{
  "name": "thevault",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "clear": "expo start --dev-client -c",
    "postinstall": "patch-package",
    "api:dev": "npm --prefix apps/api run dev",
    "api:typecheck": "npm --prefix apps/api run typecheck",
    "api:smoke": "npm --prefix apps/api run smoke",
    "bootstrap:local": "bash ./scripts/bootstrap-local.sh"
  },
  "dependencies": {
    "@expo/ui": "0.2.0-beta.9",
    "@expo/vector-icons": "^15.0.3",
    "@lottiefiles/dotlottie-react": "^0.13.5",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.75.4",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.8",
    "autoprefixer": "^10.4.0",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.34",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.11",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "framer-motion": "^12.38.0",
    "lottie-react-native": "^7.3.6",
    "moti": "^0.30.0",
    "nativewind": "^4.2.3",
    "pip": "^0.0.1",
    "postcss": "^8.4.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "patch-package": "^8.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.0.0"
  },
  "private": true,
  "overrides": {
    "react-native-worklets": "0.5.1"
  }
}
